#!/bin/bash
# mcp-hub-launcher - Wrapper script for launchd
# Sources environment from ~/.envrc (generated by: op inject -i ~/.envrc.1password -o ~/.envrc)

set -eo pipefail

# Source the 1Password-injected environment file
# Note: We don't use 'set -u' because .envrc may contain values with $ characters
# (e.g., robot$terraform) that would be interpreted as unset variables
if [[ -f "$HOME/.envrc" ]]; then
  # shellcheck source=/dev/null
  set +u # Temporarily disable nounset for sourcing
  source "$HOME/.envrc"
  set -u # Re-enable nounset
else
  echo "ERROR: ~/.envrc not found. Run: op inject -i ~/.envrc.1password -o ~/.envrc" >&2
  exit 1
fi

# Ensure PATH includes homebrew, mise shims, and common tool locations
export PATH="$HOME/.local/share/mise/shims:$HOME/.local/bin:/opt/homebrew/bin:$PATH"

# Execute mcp-hub with all arguments passed through
# exec /opt/homebrew/bin/node /opt/homebrew/bin/mcp-hub "$@"
npx --yes mcp-hub@latest "$@"
