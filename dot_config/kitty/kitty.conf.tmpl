{{/* vim: ft=gohtml */}}
{{- $brewPrefix := "/opt/homebrew" -}}
{{- if eq .chezmoi.arch "amd64" -}}
{{-   $brewPrefix = "/usr/local" -}}
{{- end -}}
# vim:fileencoding=utf-8:foldmethod=marker

# Font Settings
font_family PragmataPro VF Mono Liga
font_size 18.0
modify_font cell_height 110%

# Scrollback Settings
scrollback_lines 10000

# URL Style/Controls
url_color #0087bd
url_style curly
detect_urls yes

# Audible Bell
enable_audio_bell no
bell_on_tab "🔔 "

# Window Feels
window_padding_width 5 8
hide_window_decorations titlebar-only

# Tab Bar — hidden since we use Zellij exclusively
tab_bar_style hidden

# Shell Settings
{{- if eq .chezmoi.os "darwin" }}
shell {{ $brewPrefix }}/bin/fish --login -c "terminal-multiplexer-picker"
editor {{ $brewPrefix }}/bin/nvim
{{- else }}
shell /usr/bin/fish --login -c "terminal-multiplexer-picker"
editor /usr/bin/nvim
{{- end }}
allow_remote_control yes
shell_integration enabled

{{- if eq .chezmoi.os "darwin" }}

# macOS-specific
macos_option_as_alt left
{{- end }}

# Cursor
cursor #ebfafa
cursor_text_color #0D1116

# No confirmation on close
confirm_os_window_close 0

# Key Bindings
map kitty_mod+\ toggle_fullscreen
map f1 toggle_marker iregex 1 \\bERROR\\b 2 \\bWARNING\\b 3 \\bEXCEPTION\\b
map shift+f1 new -a 100,100
map f8 launch --title "Today's Notes" --copy-env --type=os-window --cwd ~/notes/notes {{ .chezmoi.homeDir }}/.local/share/bob/nvim-bin/nvim +YNToday

# Theme
include current-theme.conf
